---
import "../../styles/global.scss";
import "./AppLayout.scss";

import Header from "../../components/Header/Header.astro";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
};

const {
  title = "石蹴り遊び - 公式サイト",
  description = "フォークロックバンド・石蹴り遊びの公式サイトです。",
  ogImage = "img/ishikeriasobi4.jpg",
} = Astro.props;

const siteUrl = "https://rayuela.jp/";
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={pageUrl} />
  </head>
  <body>
    <Header />
    <main class="main">
      <slot />

      <!-- 下記の方々の多大なる御援助に深く感謝したい 敬称略・順不同
    大瀧詠一、浅井直樹、澁谷浩次、Boys Age、山本精一、Julio Cortázar、NEU!、tenniscoats、Neutral Milk Hotel、MOONRIDERS、工藤冬里、Cornelius、mmm、Aksak Maboul、Wilco、たま、別役実、折坂悠太、Jorge Borges、EPOCALC、Lou Reed、Saul Kripke、塊魂、ハレルヤズ、鳴らした場合、Derek Bailey、Novos Bianos、星新一、戸張大輔、i am robot and proud、Tamako Katsufuji、Gastr del Sol、頭士奈生樹、蟲師、Brian Eno、Brian Wilson、五つの赤い風船、いととと、citrus、真空ジェシカ、Kimbanourke、ジョンのサン、石原碧、Sparklehorse、Daniel Johnston、Teresa Cos、omocoro、Daily Portal Z、内海慶一、Water Walk、狩生健志、tortoise、The Sea and Cake、Arti e Mestieri、Bauhaus、加藤治郎、亀田友治、Rahmens、左右、赤瀬川原平、いがらしみきお、サニーデイ・サービス、わがつま、雀100、Aphex Twin、Nick Drake、筒井康隆、Sparklehorse、Steve Hiett, Jorge Ben、円城塔、穂村弘、駒澤零、山本邦山、灰谷魚、小西康陽、Yo La Tengo、Paul Brey、Modest Mouse、高橋葉介、Superliminal、Slay the Spire、宮城道雄、Khaki、HASYMO、吐痙唾舐汰伽藍沙箱、冥丁、あらゐけいいち、夕げ、もこみ、CAN、Erik Satie、Rocketship、Area、山尾悠子、Barry Yourgrau、佐野千明、本日休演、越冬、惹女香花、HAL9000、吉村弘、Kun、神宮寺真暉、聖飢魔II、caroline、藤子F不二雄、鈴木ジェロニモ、萩尾望都、Ashi Wakana、John Cage、Mica Levi、Simon Jeffes、Yuri Umemoto、John Tremendous、光分解、KAOMOZI、田村将太郎、Cornelius Cardew、菅野由弘、テレビ大陸音頭、momdadmefriends、坂東裕大、Ianis Xenakis、Arca、志人、ECD、23.exe、門脇綱紀、シーンズ、原口沙輔、サ柄直生、KAIRUI、零進法、榛葉暖 -->
    </main>
  </body>
</html>
